# Server
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=30182

# Backends (name=url,name=url)
RERANK_BACKENDS=rerank-node-1=http://192.168.86.173:8002,rerank-node-2=http://192.168.86.176:8002

# Upstream HTTP timeouts
TIMEOUT_CONNECT_MS=1000
TIMEOUT_READ_MS=15000

# Retry policy
RETRY_MAX_ATTEMPTS=2

# Admission queue
ADMISSION_MAX_CONCURRENT=100
ADMISSION_WAIT_TIMEOUT_MS=500

# Circuit breaker
CB_FAILURE_THRESHOLD=5
CB_RESET_TIMEOUT_SEC=30
CB_HALF_OPEN_MAX_PROBES=1
CB_HALF_OPEN_SUCCESS_THRESHOLD=1

# Routing weights: inflight*W1 + latency*W2 + error_rate*W3
ROUTING_INFLIGHT_WEIGHT=20.0
ROUTING_LATENCY_WEIGHT=0.5
ROUTING_ERROR_WEIGHT=100.0
ROUTING_EXPLORATION_RATE=0.15
ROUTING_MAX_IDLE_MS=500

# Logging
LOG_LEVEL=INFO
LOG_JSON=true
